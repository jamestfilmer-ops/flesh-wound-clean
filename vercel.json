{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/stories", "destination": "/stories/stories-index.html" },
    { "source": "/think-pieces", "destination": "/think-pieces/think-pieces-index.html" },
    { "source": "/poems", "destination": "/poems/poems-index.html" },
    { "source": "/about", "destination": "/about/about-index.html" },
    { "source": "/stories/:slug", "destination": "/stories/:slug.html" },
    { "source": "/think-pieces/:slug", "destination": "/think-pieces/:slug.html" },
    { "source": "/poems/:slug", "destination": "/poems/:slug.html" }
  ]
}
